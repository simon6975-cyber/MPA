rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 주문별 사진 경로: orders/{userId}/{orderId}/photos/{filename}
    match /orders/{userId}/{orderId}/photos/{filename} {
      // 읽기: 관리자가 제작용으로 다운로드해야 하므로 인증된 사용자 허용
      //       (현재 관리자 역할 체크 전이라 임시로 auth만 확인)
      allow read: if request.auth != null;

      // 쓰기: 본인만 자기 경로에 업로드 가능
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024  // 20MB 제한
                   && request.resource.contentType.matches('image/.*');
    }

    // PDF 출력 파일 (Cloud Functions가 생성)
    match /orders/{userId}/{orderId}/print.pdf {
      allow read: if request.auth != null;
      allow write: if false;  // Cloud Functions만 쓸 수 있음 (Admin SDK 사용)
    }

    // 썸네일 (Firebase Resize Images Extension이 생성)
    // 원본: orders/{uid}/{orderId}/photos/{file}.jpg
    // 썸네일: thumbnails/orders/{uid}/{orderId}/photos/{file}_200x200.webp
    match /thumbnails/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;  // Extension(Cloud Functions)만 쓸 수 있음
    }

    // 1:1 문의 첨부 이미지
    // 경로: inquiries/{userId}/{inquiryId}/{filename}
    match /inquiries/{userId}/{inquiryId}/{filename} {
      // 읽기: 인증된 사용자 (본인 및 관리자 모두 확인해야 하나 현재는 임시로 전체 허용)
      allow read: if request.auth != null;
      // 쓰기: 본인만 자기 경로에 업로드
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // 5MB 제한
                   && request.resource.contentType.matches('image/.*');
    }

    // 기타 경로 금지
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
